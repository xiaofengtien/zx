<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.student.archive.mapper.question.AppUserWrongQuestionBlankMapper">
    <select id="queryBlankWrongQuestionsWithJoin" resultType="com.ruoyi.student.archive.domain.question.wrongquestion.AppUserWrongQuestionBlank">
        SELECT
        wq.*
        FROM
        app_user_wrong_question_blank wq
        INNER JOIN
        question q ON wq.question_id = q.id
        INNER JOIN
        basic_config bcc ON q.subject_id = bcc.id
        WHERE
        wq.app_user_id = #{appUserId}
        AND wq.del_flag = 0
        AND bcc.biz_type = #{bizType}
        <if test="subjectId != null">
            AND bcc.id = #{subjectId}
        </if>
        <if test="questionIds != null and questionIds.size() > 0">
            AND wq.question_id IN
            <foreach collection="questionIds" item="id" open="(" separator="," close=")">
                #{id}
            </foreach>
        </if>
        <if test="type != null">
            AND q.type = #{type}
        </if>
        ORDER BY
        wq.create_time DESC
    </select>

</mapper> 