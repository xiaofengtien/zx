{
  "name": "zx-exam-client",
  "version": "1.0.0",
  "description": "考试客户端桌面应用",
  "main": ".electron-vue/main.js",
  "scripts": {
    "dev": "node .electron-vue/dev-runner.js",
    "build": "node .electron-vue/build.js",
    "build:win": "node .electron-vue/build.js --win",
    "build:mac": "node .electron-vue/build.js --mac",
    "build:linux": "node .electron-vue/build.js --linux",
    "pack": "electron-builder",
    "pack:win": "electron-builder --win",
    "pack:mac": "electron-builder --mac"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.6.0",
    "better-sqlite3": "^11.10.0",
    "element-ui": "^2.15.14",
    "vue": "^2.6.14",
    "vue-router": "^3.6.5",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "babel-loader": "^10.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.5.3",
    "style-loader": "^3.3.3",
    "url-loader": "^4.1.1",
    "vue-loader": "^15.10.0",
    "vue-template-compiler": "^2.6.14",
    "webpack": "^5.88.0",
    "webpack-dev-server": "^4.15.1"
  },
  "build": {
    "appId": "com.exam.client",
    "productName": "zx-exam-client",
    "directories": {
      "output": "dist"
    },
    "files": [
      ".electron-vue/**/*",
      "src/**/*",
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.education",
      "extendInfo": {
        "CFBundleName": "择学考试端",
        "CFBundleDisplayName": "择学考试端",
        "CFBundleExecutable": "zx-exam-client"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
