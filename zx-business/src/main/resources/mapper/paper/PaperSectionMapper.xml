<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zx.student.archive.mapper.paper.PaperSectionMapper">

    <resultMap id="PaperSectionResult" type="com.zx.student.archive.domain.paper.PaperSection">
        <id     property="id"                        column="id"                        />
        <result property="paperId"                   column="paper_id"                  />
        <result property="volumeId"                  column="volume_id"                 />
        <result property="volumeCode"                column="volume_code"               />
        <result property="sectionName"               column="section_name"              />
        <result property="sectionOrder"              column="section_order"              />
        <result property="questionCount"             column="question_count"             />
        <result property="totalScore"                column="total_score"               />
        <result property="scorePerQuestion"          column="score_per_question"        />
        <result property="instructionText"          column="instruction_text"          />
        <result property="instructionAudioUrl"      column="instruction_audio_url"     />
        <result property="instructionAudioPath"      column="instruction_audio_path"    />
        <result property="instructionAudioDuration"  column="instruction_audio_duration" />
        <result property="createTime"                column="create_time"                />
        <result property="updateTime"                column="update_time"                />
    </resultMap>

    <sql id="selectPaperSectionVo">
        select id, paper_id, volume_id, volume_code, section_name, section_order,
               question_count, total_score, score_per_question,
               instruction_text, instruction_audio_url, instruction_audio_path, instruction_audio_duration,
               create_time, update_time
        from paper_section
    </sql>

    <select id="selectByPaperId" parameterType="Integer" resultMap="PaperSectionResult">
        <include refid="selectPaperSectionVo"/>
        where paper_id = #{paperId}
        order by volume_id asc, section_order asc
    </select>

    <select id="selectByPaperIdAndVolumeCode" resultMap="PaperSectionResult">
        <include refid="selectPaperSectionVo"/>
        where paper_id = #{paperId} and volume_code = #{volumeCode}
        order by section_order asc
    </select>

    <select id="selectByVolumeId" parameterType="Integer" resultMap="PaperSectionResult">
        <include refid="selectPaperSectionVo"/>
        where volume_id = #{volumeId}
        order by section_order asc
    </select>

    <delete id="deleteByPaperId" parameterType="Integer">
        delete from paper_section where paper_id = #{paperId}
    </delete>

</mapper>


