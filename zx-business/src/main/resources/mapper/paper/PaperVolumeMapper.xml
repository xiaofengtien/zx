<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zx.student.archive.mapper.paper.PaperVolumeMapper">

    <resultMap id="PaperVolumeResult" type="com.zx.student.archive.domain.paper.PaperVolume">
        <id     property="id"                    column="id"                    />
        <result property="paperId"               column="paper_id"              />
        <result property="volumeCode"            column="volume_code"           />
        <result property="volumeName"            column="volume_name"           />
        <result property="volumeOrder"           column="volume_order"          />
        <result property="volumeAudioUrl"        column="volume_audio_url"      />
        <result property="volumeAudioPath"       column="volume_audio_path"     />
        <result property="volumeAudioDuration"  column="volume_audio_duration" />
        <result property="createTime"           column="create_time"           />
        <result property="updateTime"           column="update_time"           />
    </resultMap>

    <sql id="selectPaperVolumeVo">
        select id, paper_id, volume_code, volume_name, volume_order,
               volume_audio_url, volume_audio_path, volume_audio_duration,
               create_time, update_time
        from paper_volume
    </sql>

    <select id="selectByPaperId" parameterType="Integer" resultMap="PaperVolumeResult">
        <include refid="selectPaperVolumeVo"/>
        where paper_id = #{paperId}
        order by volume_order asc
    </select>

    <select id="selectByPaperIdAndVolumeCode" resultMap="PaperVolumeResult">
        <include refid="selectPaperVolumeVo"/>
        where paper_id = #{paperId} and volume_code = #{volumeCode}
        limit 1
    </select>

    <delete id="deleteByPaperId" parameterType="Integer">
        delete from paper_volume where paper_id = #{paperId}
    </delete>

</mapper>



